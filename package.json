{
  "name": "shareboost-pro",
  "version": "2.0.0",
  "description": "Professional automated Facebook post sharing platform with claymorphism UI, 120Hz smooth refresh, and advanced session management",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "production": "cross-env NODE_ENV=production node server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md,css,html}\"",
    "build": "npm run lint && npm test",
    "precommit": "npm run format && npm run lint",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop shareboost-pro",
    "pm2:restart": "pm2 restart shareboost-pro",
    "pm2:delete": "pm2 delete shareboost-pro",
    "pm2:logs": "pm2 logs shareboost-pro",
    "pm2:monit": "pm2 monit",
    "logs:clean": "rm -rf logs/*.log",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "update:deps": "npm update --save",
    "docker:build": "docker build -t shareboost-pro .",
    "docker:run": "docker run -p 5000:5000 shareboost-pro",
    "backup:logs": "tar -czf logs-backup-$(date +%Y%m%d-%H%M%S).tar.gz logs/",
    "install:all": "npm install",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "keywords": [
    "facebook",
    "automation",
    "sharing",
    "boost",
    "social-media",
    "express",
    "claymorphism",
    "web-scraping",
    "facebook-api",
    "social-boost",
    "auto-share",
    "facebook-automation",
    "share-boost",
    "120hz",
    "smooth-refresh"
  ],
  "author": {
    "name": "ShareBoost Team",
    "email": "support@shareboost.com",
    "url": "https://shareboost.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/shareboost-pro.git",
    "directory": "."
  },
  "bugs": {
    "url": "https://github.com/yourusername/shareboost-pro/issues",
    "email": "bugs@shareboost.com"
  },
  "homepage": "https://github.com/yourusername/shareboost-pro#readme",
  "engines": {
    "node": ">=14.0.0 <21.0.0",
    "npm": ">=6.0.0",
    "yarn": ">=1.22.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "express-session": "^1.18.0",
    "cookie-parser": "^1.4.6",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "connect-redis": "^7.1.0",
    "csrf": "^3.1.0",
    "helmet-csp": "^2.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "pm2": "^5.3.0",
    "cross-env": "^7.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.1.0",
    "@types/jest": "^29.5.10",
    "faker": "^5.5.3"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "peerDependencies": {
    "pm2": "^5.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/tests/fixtures/",
      "/public/"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ],
    "collectCoverageFrom": [
      "server.js",
      "routes/*.js",
      "controllers/*.js",
      "services/*.js",
      "utils/*.js",
      "!**/node_modules/**",
      "!**/public/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    },
    "setupFilesAfterEnv": ["<rootDir>/tests/setup.js"],
    "verbose": true
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": ["eslint:recommended", "plugin:prettier/recommended"],
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
      "no-async-promise-executor": "off",
      "prettier/prettier": "error",
      "no-var": "error",
      "prefer-const": "error",
      "eqeqeq": ["error", "always"],
      "curly": ["error", "all"],
      "no-multiple-empty-lines": ["error", { "max": 1, "maxEOF": 0 }],
      "no-trailing-spaces": "error"
    },
    "globals": {
      "process": "readonly",
      "__dirname": "readonly",
      "performance": "readonly",
      "requestAnimationFrame": "readonly"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "jsxSingleQuote": false,
    "jsxBracketSameLine": false
  },
  "nodemonConfig": {
    "watch": ["server.js", "routes/", "controllers/", "services/", "utils/", "public/"],
    "ignore": ["logs/*", "node_modules", "tests/", "coverage/", "*.test.js", "*.spec.js"],
    "ext": "js,json,html,css",
    "delay": 1000,
    "exec": "npm run lint",
    "env": {
      "NODE_ENV": "development"
    },
    "events": {
      "start": "echo '🚀 ShareBoost Pro starting...'",
      "crash": "echo '❌ Application crashed!'",
      "restart": "echo '🔄 Restarting application...'"
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "lint-staged": {
    "*.js": ["eslint --fix", "prettier --write", "git add"],
    "*.{json,md,css,html}": ["prettier --write", "git add"]
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "maintained node versions",
    "not dead"
  ],
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/yourusername"
  }
}